{
  "db_name": "PostgreSQL",
  "query": "\n        SELECT f.id, f.owner_id, s.url, f.title, f.description, f.is_public, f.created_at,\n               COUNT(fs.user_id) as \"subscriber_count!\"\n        FROM feeds f\n        JOIN sources s ON f.source_id = s.id\n        LEFT JOIN feed_subscriptions fs ON f.id = fs.feed_id\n        WHERE f.is_public = true\n          AND (f.title ILIKE $1 OR f.description ILIKE $1 OR s.url ILIKE $1)\n        GROUP BY f.id, s.url\n        ORDER BY COUNT(fs.user_id) DESC, f.created_at DESC\n        LIMIT 50\n        ",
